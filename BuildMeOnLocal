#!/bin/bash
set -a

if [ "$#" -ne 1 ]; then
  echo "Usage: ./BuildMeOnLocal <path to NEKRS_HOME>"
  echo -e "If okay with the default \$HOME/.local/nekrs, press ENTER to continue"
  echo "Or press Ctrl+C to quit"
  read -r -s KEY
  export NEKRS_HOME=$HOME/.local/nekrs
else
  export NEKRS_HOME=$1
fi

#... set the build and install directories
CWD=$PWD
echo -e "\033[35mInstalling nekRS at $NEKRS_HOME\033[m"
export INSTALL_DIR=$NEKRS_HOME
#...

#... set some environment variables
: ${ENABLE_SMARTREDIS:="OFF"}
export CC=mpicc
export CXX=mpic++
export FC=mpif77

# Local defaults: CPU-only (OCCA SERIAL backend), no GPU and no Metal
: ${OCCA_ENABLE_CUDA:=OFF}
: ${OCCA_ENABLE_HIP:=OFF}
: ${OCCA_ENABLE_OPENCL:=OFF}
: ${OCCA_ENABLE_DPCPP:=OFF}
: ${OCCA_ENABLE_METAL:=OFF}
: ${NEKRS_GPU_MPI:=OFF}
: ${ENABLE_AMGX:=OFF}
#...

#... build SmartRedis if enabled
if [ ${ENABLE_SMARTREDIS} == "ON" ]; then
  SMARTREDIS_LIB=""
  for ext in so dylib; do
    if [ -f "$NEKRS_HOME/SmartRedis/install/lib/libsmartredis.${ext}" ]; then
      SMARTREDIS_LIB="$NEKRS_HOME/SmartRedis/install/lib/libsmartredis.${ext}"
      break
    fi
  done
  if [ -n "$SMARTREDIS_LIB" ]; then
    echo -e "\033[35mFound SmartRedis at $SMARTREDIS_LIB\033[m"
  else
    echo -e "\033[35mBuilding SmartRedis first ...\033[m"
    if [ ! -d "$NEKRS_HOME" ]; then
      mkdir -p $NEKRS_HOME
    fi
    cd $NEKRS_HOME
    git clone https://github.com/rickybalin/SmartRedis.git
    cd SmartRedis
    make lib
    cd $CWD
    echo -e "\033[35mDone building SmartRedis\033[m"
    echo
  fi
fi
#...

#... build nekRS
NEKRS_CMAKE_ARGS=(
  -DOCCA_ENABLE_CUDA="${OCCA_ENABLE_CUDA}"
  -DOCCA_ENABLE_HIP="${OCCA_ENABLE_HIP}"
  -DOCCA_ENABLE_OPENCL="${OCCA_ENABLE_OPENCL}"
  -DOCCA_ENABLE_DPCPP="${OCCA_ENABLE_DPCPP}"
  -DOCCA_ENABLE_METAL="${OCCA_ENABLE_METAL}"
  -DNEKRS_GPU_MPI="${NEKRS_GPU_MPI}"
  -DENABLE_AMGX="${ENABLE_AMGX}"
  -DENABLE_ADIOS=OFF
)

echo ""
if [ ${ENABLE_SMARTREDIS} == "ON" ]; then
  echo -e "\033[35mBuilding nekRS WITH SmartRedis ...\033[m"
  ./build.sh "${NEKRS_CMAKE_ARGS[@]}" \
    -DENABLE_SMARTREDIS=ON -DSMARTREDIS_INSTALL_DIR=$NEKRS_HOME/SmartRedis/install
else
  echo -e "\033[35mBuilding nekRS WITHOUT external dependencies ...\033[m"
  ./build.sh "${NEKRS_CMAKE_ARGS[@]}"
fi
#...
